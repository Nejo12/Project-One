# Shared local development reference values.
# Runtime apps should use their app-specific .env files under apps/*.

NODE_ENV=development

# Local URLs
WEB_APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:3001
INTERNAL_WORKER_TOKEN=change-me

# Local infrastructure
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/moments?schema=public
REDIS_URL=redis://localhost:6379

# Local object storage
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=moments-dev
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# Local payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
